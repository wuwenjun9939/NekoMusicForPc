#include <windows.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION @FILEVERSION_NUMERIC@,0
PRODUCTVERSION @PRODUCTVERSION_NUMERIC@,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "080404b0"
        BEGIN
            VALUE "CompanyName", "FantasyNetwork"
            VALUE "FileDescription", "Neko云音乐"
            VALUE "FileVersion", "@PROJECT_VERSION@"
            VALUE "InternalName", "NekoMusic"
            VALUE "LegalCopyright", "Copyright (C) Neko"
            VALUE "OriginalFilename", "NekoMusic.exe"
            VALUE "ProductName", "Neko云音乐"
            VALUE "ProductVersion", "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x804, 1200
    END
END

// Icon resource
IDI_ICON1 ICON "app.ico"
