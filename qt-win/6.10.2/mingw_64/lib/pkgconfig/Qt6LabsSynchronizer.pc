prefix=/Users/qt/work/install
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 LabsSynchronizer
Description: Qt LabsSynchronizer module
Version: 6.10.2
Libs: -L${libdir} -lQt6LabsSynchronizer
Cflags: -I${includedir}/QtLabsSynchronizer -I${includedir} -DQT_LABSSYNCHRONIZER_LIB
Requires: Qt6Core
